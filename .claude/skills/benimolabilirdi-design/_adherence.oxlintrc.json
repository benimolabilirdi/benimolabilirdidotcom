{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/flow/**",
              "components/money/**",
              "ui_kits/app/**",
              "ui_kits/sharecard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Nunito|DM Sans))/i]",
        "message": "Font not provided by the design system. Available: Nunito, DM Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|positive|sparkle)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'positive' | 'sparkle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BudgetMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:total|remaining|label|style|key|ref|className|style|children)$/]",
        "message": "<BudgetMeter> doesn't accept that prop. Declared props: total, remaining, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|iconLeft|iconRight|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, iconLeft, iconRight, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|positive|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'positive' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|interactive|tone|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, interactive, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|sunken|navy)$/]",
        "message": "<Card> tone must be one of 'paper' | 'sunken' | 'navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:emoji|label|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<CategoryTile> doesn't accept that prop. Declared props: emoji, label, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|emoji|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, emoji, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CountUpNumber'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|prefix|suffix|decimals|duration|size|color|weight|animate|style|key|ref|className|style|children)$/]",
        "message": "<CountUpNumber> doesn't accept that prop. Declared props: value, prefix, suffix, decimals, duration, size, color, weight, animate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LiveCounter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|tickInterval|style|key|ref|className|style|children)$/]",
        "message": "<LiveCounter> doesn't accept that prop. Declared props: value, label, tickInterval, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|style|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: value, onChange, placeholder, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SparkleBurst'] > JSXAttribute > JSXIdentifier[name!=/^(?:trigger|children|style|key|ref|className|style|children)$/]",
        "message": "<SparkleBurst> doesn't accept that prop. Declared props: trigger, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|current|style|key|ref|className|style|children)$/]",
        "message": "<StepIndicator> doesn't accept that prop. Declared props: steps, current, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaxBreakdown'] > JSXAttribute > JSXIdentifier[name!=/^(?:paid|tax|style|key|ref|className|style|children)$/]",
        "message": "<TaxBreakdown> doesn't accept that prop. Declared props: paid, tax, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WishItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:emoji|name|price|qty|onAdd|onRemove|style|key|ref|className|style|children)$/]",
        "message": "<WishItem> doesn't accept that prop. Declared props: emoji, name, price, qty, onAdd, onRemove, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
